<!DOCTYPE html>
<html>
<head>
    <title>City Central Library</title>
    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial;
        }
        body{
            background-color: #f4f4f4;
        }
        .navbar{
            background-color: #2c3e50;
            color: white;
            padding: 15px;
            text-align: center;
            font-size: 28px;
            font-weight: bold;
        }
        .banner{
            background-color: lightblue;
            text-align: center;
            padding: 40px;
        }
        .banner h2{
            font-size: 35px;
            margin-bottom: 10px;
        }
        .banner p{
            font-size: 18px;
        }
        .search-box{
            text-align: center;
            margin: 20px;
        }
        .search-box input{
            width: 50%;
            padding: 10px;
            font-size: 16px;
            border: 1px solid gray;
            border-radius: 5px;
        }
        .table-box{
            width: 85%;
            margin: auto;
            background-color: white;
            padding: 20px;
            box-shadow: 0 0 10px gray;
            border-radius: 10px;
        }
        table{
            width: 100%;
            border-collapse: collapse;
        }
        th, td{
            border: 1px solid gray;
            padding: 12px;
            text-align: center;
        }
        th{
            background-color: #3498db;
            color: white;
        }
        tr:hover{
            background-color: #f1f1f1;
        }
        .available{
            background-color: lightgreen;
        }
        .notavailable{
            background-color: pink;
        }
        .footer{
            background-color: #2c3e50;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 30px;
        }
    </style>
</head>
<body>
    <div class="navbar">
        City Central Library
    </div>
    <div class="banner">
        <h2>Welcome to Library</h2>
        <p>Search and check books easily</p>
    </div>

    <div class="search-box">
        <input type="text" id="search" placeholder="Search book" onkeyup="searchBook()">
    </div>
    <div class="table-box">
        <table id="library">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>ISBN</th>
                <th>Availability</th>
            </tr>
            <tr>
                <td>Harry Potter</td>
                <td>J.K. Rowling</td>
                <td>101</td>
                <td class="available">Available</td>
            </tr>
            <tr>
                <td>Wings of Fire</td>
                <td>A.P.J Abdul Kalam</td>
                <td>102</td>
                <td class="notavailable">Not Available</td>
            </tr>
            <tr>
                <td>The Alchemist</td>
                <td>Paulo Coelho</td>
                <td>103</td>
                <td class="available">Available</td>
            </tr>
            <tr>
                <td>Rich Dad Poor Dad</td>
                <td>Robert Kiyosaki</td>
                <td>104</td>
                <td class="available">Available</td>
            </tr>
        </table>
    </div>
    <div class="footer">
        2026 City Central Library
    </div>
    <script>
        function searchBook() {
            var input = document.getElementById("search").value.toLowerCase();
            var table = document.getElementById("library");
            var tr = table.getElementsByTagName("tr");
            for (var i = 1; i < tr.length; i++) {
                var td = tr[i].getElementsByTagName("td")[0];
                if (td) {
                    var text = td.innerHTML.toLowerCase();

                    if (text.indexOf(input) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }
            }
        }
    </script>
</body>
</html>
